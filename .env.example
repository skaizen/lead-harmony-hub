# Public — exposed to the browser. Put real values in .env (gitignored).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets — set via Lovable's secret manager OR your hosting env.
# (Listed here for documentation; do NOT put real values in this file.)
# In Lovable use the EXT_ prefixed names (VITE_/SUPABASE_ are reserved prefixes).
# Locally/in Antigravity you can use SUPABASE_SERVICE_ROLE_KEY directly.
# EXT_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# EXT_SUPABASE_SERVICE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# ERPNEXT_BASE_URL=https://erp.example.com
# ERPNEXT_API_KEY=
# ERPNEXT_API_SECRET=