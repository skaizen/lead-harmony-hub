# ============================================================
#  Lead Ops Dashboard — Environment Variables
# ============================================================
#  1. Copy this file to `.env` (already gitignored).
#  2. Replace the placeholder values below with your real keys.
#  3. Restart the dev server after editing.
# ============================================================

# -----------------------------------------------------------
#  PUBLIC (browser-visible) — Supabase project credentials
# -----------------------------------------------------------
#  Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------
#  SERVER-ONLY — Supabase service role + ERPNext API
# -----------------------------------------------------------
#  These are NEVER sent to the browser.
#  In Lovable → use the secret manager for these (EXT_ prefix required).
#  Locally / in Antigravity → paste them here in your `.env` file.

# Supabase service role key (Settings → API → service_role key)
EXT_SUPABASE_URL=https://your-project.supabase.co
EXT_SUPABASE_SERVICE_KEY=your-service-role-key

# ERPNext instance credentials
ERPNEXT_BASE_URL=https://wak-lpp.m.frappe.cloud/
ERPNEXT_API_KEY=your-api-key
ERPNEXT_API_SECRET=your-api-secret

# -----------------------------------------------------------
#  WORDPRESS WEBHOOK — secret for HMAC signature verification
# -----------------------------------------------------------
#  Generate a random string and set it in both Lovable secrets
#  and your WordPress form plugin webhook settings.
WORDPRESS_WEBHOOK_SECRET=your-random-webhook-secret

# -----------------------------------------------------------
#  META / FACEBOOK ADS — Marketing API
# -----------------------------------------------------------
#  Get access token from: https://developers.facebook.com/tools/explorer
#  Ad account ID is numeric (e.g. 1234567890). API version is optional (default v19.0).
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=your-ad-account-id
META_API_VERSION=v19.0

# -----------------------------------------------------------
#  GOOGLE ADS API — REST + OAuth refresh token flow
# -----------------------------------------------------------
#  Create OAuth credentials in Google Cloud Console, obtain a refresh
#  token via OAuth flow (or from Ads API Developer Token page).
#  Login Customer ID is optional — required for manager accounts only.
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-customer-id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-manager-customer-id
